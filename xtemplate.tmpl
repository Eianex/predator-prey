const FIXED_W = 1500;
const FIXED_H = 800;

function show_infobox() {
    const infobox = document.getElementById("infobox");
    if (!infobox) return;

    infobox.style.display = "block";

    const w = infobox.offsetWidth;
    const h = infobox.offsetHeight;

    const left = Math.max(0, (window.innerWidth - w) / 2);
    const top = Math.max(0, (window.innerHeight - h) / 2);

    infobox.style.left = left + "px";
    infobox.style.top = top + "px";
}

function focus_game_canvas() {
    const canvas = document.getElementById("canvas");
    if (!canvas) return;

    try {
        canvas.focus({ preventScroll: true });
    } catch (_) {
        canvas.focus();
    }
}

function lock_fixed_canvas() {
    const body = document.body;
    const html = document.documentElement;
    const shell = document.getElementById("app-shell");
    const canvas = document.getElementById("canvas");
    const canvas3d = document.getElementById("canvas3d");
    const transfer = document.getElementById("transfer");
    const htmlDiv = document.getElementById("html");
    const pyconsole = document.getElementById("pyconsole");
    const crt = document.getElementById("crt");
    const infobox = document.getElementById("infobox");

    if (html) {
        html.style.minWidth = FIXED_W + "px";
        html.style.overflowX = "auto";
        html.style.overflowY = "auto";
    }

    if (body) {
        body.style.minWidth = FIXED_W + "px";
        body.style.overflowX = "auto";
        body.style.overflowY = "auto";
    }

    if (transfer) {
        transfer.style.width = FIXED_W + "px";
        transfer.style.margin = "10px auto 8px auto";
        transfer.style.pointerEvents = "none";
    }

    if (htmlDiv) {
        htmlDiv.style.width = FIXED_W + "px";
        htmlDiv.style.minWidth = FIXED_W + "px";
        htmlDiv.style.maxWidth = FIXED_W + "px";
        htmlDiv.style.margin = "0 auto";
        htmlDiv.style.pointerEvents = "none";
    }

    if (pyconsole) {
        pyconsole.style.width = FIXED_W + "px";
        pyconsole.style.minWidth = FIXED_W + "px";
        pyconsole.style.maxWidth = FIXED_W + "px";
        pyconsole.style.margin = "0 auto";
        pyconsole.style.pointerEvents = "none";
    }

    if (crt) {
        crt.style.pointerEvents = "none";
    }

    if (infobox) {
        infobox.style.pointerEvents = "none";
    }

    if (shell) {
        shell.style.width = FIXED_W + "px";
        shell.style.height = FIXED_H + "px";
        shell.style.minWidth = FIXED_W + "px";
        shell.style.minHeight = FIXED_H + "px";
        shell.style.maxWidth = FIXED_W + "px";
        shell.style.maxHeight = FIXED_H + "px";
        shell.style.position = "relative";
        shell.style.margin = "0 auto";
        shell.style.overflow = "hidden";
    }

    if (canvas) {
        canvas.style.width = FIXED_W + "px";
        canvas.style.height = FIXED_H + "px";
        canvas.style.minWidth = FIXED_W + "px";
        canvas.style.minHeight = FIXED_H + "px";
        canvas.style.maxWidth = FIXED_W + "px";
        canvas.style.maxHeight = FIXED_H + "px";
        canvas.style.position = "absolute";
        canvas.style.left = "0px";
        canvas.style.top = "0px";
        canvas.style.right = "auto";
        canvas.style.bottom = "auto";
        canvas.style.margin = "0";
        canvas.style.padding = "0";
        canvas.style.border = "0";
        canvas.style.transform = "none";
        canvas.style.display = "block";
        canvas.style.pointerEvents = "auto";
        canvas.style.touchAction = "none";
        canvas.style.zIndex = "50";
    }

    if (canvas3d) {
        canvas3d.hidden = true;
        canvas3d.style.display = "none";
        canvas3d.style.pointerEvents = "none";
        canvas3d.style.width = FIXED_W + "px";
        canvas3d.style.height = FIXED_H + "px";
        canvas3d.style.position = "absolute";
        canvas3d.style.left = "0px";
        canvas3d.style.top = "0px";
        canvas3d.style.zIndex = "1";
    }
}

function install_fixed_canvas_lock() {
    lock_fixed_canvas();

    window.window_resize = function() {
        lock_fixed_canvas();
        return false;
    };

    window.addEventListener("resize", function() {
        requestAnimationFrame(lock_fixed_canvas);
        setTimeout(lock_fixed_canvas, 0);
        setTimeout(lock_fixed_canvas, 50);
    });

    const canvas = document.getElementById("canvas");
    if (canvas) {
        canvas.addEventListener("pointerdown", function() {
            focus_game_canvas();
        }, { passive: true });

        canvas.addEventListener("mousedown", function() {
            focus_game_canvas();
        }, { passive: true });

        canvas.addEventListener("touchstart", function() {
            focus_game_canvas();
        }, { passive: true });
    }

    if (window.ResizeObserver) {
        const ro = new ResizeObserver(function() {
            lock_fixed_canvas();
        });

        const shell = document.getElementById("app-shell");
        if (document.body) ro.observe(document.body);
        if (document.documentElement) ro.observe(document.documentElement);
        if (shell) ro.observe(shell);
    }

    setInterval(lock_fixed_canvas, 500);
}

</script>

